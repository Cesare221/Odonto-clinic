{
  "name": "clinica-odonto-fullstack",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd frontend && vite --port 5173",
    "backend": "cd backend && node server.js",
    "backend:dev": "cd backend && nodemon server.js",
    "seed": "cd backend && node seed.js",
    "reset:demo": "cd backend && node scripts/reset-demo-data.js",
    "build": "cd frontend && vite build",
    "lint": "eslint . --ext .js,.jsx",
    "test": "node --test tests/**/*.test.js",
    "format": "prettier --write .",
    "preview": "cd frontend && vite preview"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.40.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "mongoose": "^9.6.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.3.0",
    "sonner": "^2.0.7",
    "speakeasy": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.14",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  }
}
